# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/stremio-addon

# TMDB API Key (get from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# Dashboard Admin Credentials
DASHBOARD_USER=admin
DASHBOARD_PASS=yourpassword123

# Addon Base URL (your deployed server URL)
ADDON_BASE_URL=https://your-addon-url.com

# Server Port
PORT=3000

# Secret key for internal API
API_SECRET=your_secret_key_here
