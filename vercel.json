{
  "version": 2,
  "buildCommand": "npm install",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "node_modules/**",
          "public/**",
          "routes/**",
          "models/**",
          "services/**"
        ]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "server.js" }]
}
